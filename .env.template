# ============================================================
# GrelinMisay 健身目标管理助手 - 环境配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- LLM 模型配置 ---
# 支持 OpenAI 兼容接口（OpenAI / 智谱 GLM / DeepSeek / 本地模型）
# 示例：智谱 GLM
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_NAME=GLM-4.6V-Flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- LLM 调用重试与超时 ---
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=2

# --- ReAct 推理配置 ---
REACT_MAX_ITERATIONS=10
REACT_OUTPUT_VALIDATION=true
REACT_MAX_RETRIES=3

# --- 记忆管理配置 ---
MEMORY_WINDOW_SIZE=12
MEMORY_COMPRESSION_ENABLED=true
MEMORY_MAX_TOKENS=8000

# --- 数据库配置 ---
DB_TYPE=sqlite
DB_PATH=./data/agent.db
# 如使用 PostgreSQL:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=agent
# DB_PASSWORD=agent123
# DB_NAME=agent_db

# --- 服务配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=false

# --- 日志配置 ---
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
